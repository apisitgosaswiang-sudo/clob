{
  "rules": {
    "clob": {
      ".read": "auth != null",
      ".write": "auth != null",
      "exercises": {
        ".read": true,
        ".write": "auth != null"
      },
      "exercisePreferences": {
        "$uid": {
          ".read": "$uid === auth.uid",
          ".write": "$uid === auth.uid"
        }
      }
    },
    "workoutTrackerData": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
